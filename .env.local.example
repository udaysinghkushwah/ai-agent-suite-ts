# ================================================================
# AI AGENT SUITE (TypeScript) — Environment Variables
# Copy this to .env.local and fill in your actual API keys.
# ================================================================

# ── Anthropic Claude (REQUIRED) ─────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LangSmith Observability (REQUIRED) ──────────────────────────
# Sign up free at: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ai-agent-suite-ts

# ── Tavily Web Search (OPTIONAL) ────────────────────────────────
# Falls back to DuckDuckGo if not set.
# Get your key at: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ── Model Config ─────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
